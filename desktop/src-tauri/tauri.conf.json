{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Board",
  "version": "0.1.0",
  "identifier": "site.thite.board",
  "build": {
    "frontendDist": "https://board.thite.site",
    "devUrl": "https://board.thite.site"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Board",
        "url": "https://board.thite.site",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "category": "Productivity",
    "shortDescription": "Live desktop shell for board.thite.site",
    "longDescription": "Thin Tauri wrapper around the Board web app. Loads the live site each launch, so every Cloudflare Pages deploy ships to desktop automatically.",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-"
    }
  }
}
