# Build output
dist/
.wrangler/

# Generated seed (regenerated by `npm run db:import:*` / `npm run notes:apple:*` / `npm run tags:*`)
db/seed.sql
db/seed.apple.sql
db/seed.suggestions.sql
db/seed.auto-apply-high.sql

# Tagging-batch artifacts (regenerated by scripts/cluster-notes.py + parallel subagents)
db/clusters/clusters.jsonl
db/clusters/cluster-summary.json
db/clusters/untagged-notes.jsonl
db/clusters/labels.json
db/clusters/proposal.md
db/clusters/labeler-output.md
db/chunks/chunk-*.jsonl
db/chunks/chunk-*.log
db/tag-suggestions-raw.jsonl
db/tag-suggestions-raw-v2.jsonl
db/tag-suggestions-final.jsonl
# Keep: db/clusters/labeler-prompt.md, db/chunks/per-note-prompt.md, db/eval/* (taxonomy + golden + calibration)
!db/clusters/labeler-prompt.md
!db/chunks/per-note-prompt.md

# Ephemeral subagent artifacts (scout context.md, worker progress.md)
context.md
progress.md

# Audit sample cache (regenerated by `npm run tags:audit:refresh`)
db/eval/.audit-sample-cache.json

# Personal source data — never commit. Imported via NEWNOTES_PATH or ./newnotes.json.
newnotes.json

# Local tooling state
output/

# Local config backups
*.bak

# Node
node_modules/
*.log

# Editor
.DS_Store
.vscode/
.idea/

# Playwright session state
.playwright-cli/

# Tauri desktop shell — Rust build output + codegen
# Cargo.lock IS committed (binary crate convention) for reproducible builds.
desktop/src-tauri/target/
desktop/src-tauri/gen/

# Tauri iOS shell — Rust build output + codegen + Xcode scratch
# Cargo.lock IS committed (binary crate convention) for reproducible builds.
mobile/src-tauri/target/
mobile/src-tauri/gen/
mobile/src-tauri/Pods/
mobile/src-tauri/Podfile.lock
mobile/src-tauri/*.xcworkspace/xcuserdata/
mobile/src-tauri/*.xcodeproj/xcuserdata/
mobile/src-tauri/*.xcodeproj/project.xcworkspace/xcuserdata/

# Local secrets for wrangler pages dev
.dev.vars
.env
.env.local

# pi agent harness state
.pi/

# Local data dumps + backups (regeneratable from D1)
db/backups/
db/round3/
db/seed.auto-apply-suggestions.sql
db/seed.strip-sweep.sql
# db/semantic-layout.json is tracked as an EMPTY STUB so server/lib/
# semantic-layout.ts can statically import it in the Pages build. The local
# `npm run semantic:build` overwrites it with a ~90KB UMAP blob — do NOT
# `git add` that overwrite. Tip: `git update-index --skip-worktree db/semantic-layout.json`.
.local-backup
*.local-backup

# Idea-graph render artifacts (large media)
scripts/idea/*.mp4
scripts/idea/*.gif
scripts/idea/*.png
scripts/idea/ideas-over-time.html
implementation-notes/scratch/

