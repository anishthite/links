{
  "name": "links",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Personal link board — Cloudflare Worker + D1 + Hono + Vite + @chenglou/pretext",
  "scripts": {
    "dev": "concurrently -k -n vite,wrangler -c blue,magenta \"vite build --watch --mode development\" \"wait-on dist/index.html && wrangler dev --port=8788 --ip=127.0.0.1\"",
    "dev:vite": "vite",
    "dev:cf": "wrangler dev --port=8788 --ip=127.0.0.1",
    "preview:cf": "vite build && wrangler dev --port=8788",
    "build": "vite build",
    "preview": "vite preview",
    "db:create": "wrangler d1 create links-board-db",
    "db:migrate:local": "wrangler d1 execute links-board-db --local --file=db/migrations/0001_initial.sql",
    "db:migrate:remote": "wrangler d1 execute links-board-db --remote --file=db/migrations/0001_initial.sql",
    "db:migrate:tags:local": "wrangler d1 execute links-board-db --local --file=db/migrations/0002_tag_suggestions.sql",
    "db:migrate:tags:remote": "wrangler d1 execute links-board-db --remote --file=db/migrations/0002_tag_suggestions.sql",
    "db:migrate:standalone:local": "wrangler d1 execute links-board-db --local --file=db/migrations/0003_tags_standalone.sql",
    "db:migrate:standalone:remote": "wrangler d1 execute links-board-db --remote --file=db/migrations/0003_tags_standalone.sql",
    "db:migrate:ai-log:local": "wrangler d1 execute links-board-db --local --file=db/migrations/0004_ai_arrange_log.sql",
    "db:migrate:ai-log:remote": "wrangler d1 execute links-board-db --remote --file=db/migrations/0004_ai_arrange_log.sql",
    "db:migrate:agent-sessions:local": "wrangler d1 execute links-board-db --local --file=db/migrations/0005_agent_sessions.sql",
    "db:migrate:agent-sessions:remote": "wrangler d1 execute links-board-db --remote --file=db/migrations/0005_agent_sessions.sql",
    "db:migrate:agent-history:local": "wrangler d1 execute links-board-db --local --file=db/migrations/0006_agent_history.sql",
    "db:migrate:agent-history:remote": "wrangler d1 execute links-board-db --remote --file=db/migrations/0006_agent_history.sql",
    "db:migrate:agent-pi:local": "wrangler d1 execute links-board-db --local --file=db/migrations/0007_agent_pi_entries.sql",
    "db:migrate:agent-pi:remote": "wrangler d1 execute links-board-db --remote --file=db/migrations/0007_agent_pi_entries.sql",
    "db:migrate:daily-page:local": "wrangler d1 execute links-board-db --local --file=db/migrations/0009_daily_pages.sql",
    "db:migrate:daily-page:remote": "wrangler d1 execute links-board-db --remote --file=db/migrations/0009_daily_pages.sql",
    "db:migrate:wiki:local": "wrangler d1 execute links-board-db --local --file=db/migrations/0010_wiki_pages.sql",
    "db:migrate:wiki:remote": "wrangler d1 execute links-board-db --remote --file=db/migrations/0010_wiki_pages.sql",
    "tags:backfill:local": "tsx scripts/backfill-tags-standalone.ts",
    "tags:backfill:local:apply": "tsx scripts/backfill-tags-standalone.ts --apply",
    "tags:backfill:remote:apply": "tsx scripts/backfill-tags-standalone.ts --apply --remote",
    "tags:strip:local": "tsx scripts/strip-hashtags-sweep.ts",
    "tags:strip:local:apply": "tsx scripts/strip-hashtags-sweep.ts --apply",
    "tags:strip:remote": "tsx scripts/strip-hashtags-sweep.ts --remote",
    "tags:strip:remote:apply": "tsx scripts/strip-hashtags-sweep.ts --apply --remote",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:import:local": "tsx scripts/import-newnotes.ts > db/seed.sql && wrangler d1 execute links-board-db --local --file=db/seed.sql",
    "db:import:remote": "tsx scripts/import-newnotes.ts > db/seed.sql && wrangler d1 execute links-board-db --remote --file=db/seed.sql",
    "notes:apple:export": "tsx scripts/export-apple-notes.ts > db/seed.apple.sql",
    "notes:apple:local": "tsx scripts/export-apple-notes.ts > db/seed.apple.sql && wrangler d1 execute links-board-db --local --file=db/seed.apple.sql",
    "notes:apple:remote": "tsx scripts/export-apple-notes.ts > db/seed.apple.sql && wrangler d1 execute links-board-db --remote --file=db/seed.apple.sql",
    "tags:stitch": "python3 scripts/stitch-suggestions.py",
    "tags:promote": "python3 scripts/apply-promotions.py",
    "tags:eval": "tsx scripts/eval-classifier.ts",
    "tags:eval:auto": "tsx scripts/eval-auto-tagger.ts",
    "tags:holdout": "tsx scripts/tag-golden.ts --out db/eval/holdout-50.jsonl --exclude db/eval/golden-50.jsonl --target 50",
    "whiteboard:eval": "tsx scripts/eval-arrange.ts",
    "semantic:build": "tsx scripts/build-semantic-layout.ts",
    "semantic:build:remote": "tsx scripts/build-semantic-layout.ts --remote",
    "wiki:seed": "tsx scripts/seed-wiki.ts > db/seed.wiki.sql",
    "wiki:seed:remote": "tsx scripts/seed-wiki.ts --remote > db/seed.wiki.sql",
    "similar:eval": "tsx scripts/eval-similar-notes.ts",
    "tags:diagnose-misses": "tsx scripts/diagnose-load-misses.ts",
    "tags:audit": "tsx scripts/audit-high-conf.ts",
    "tags:audit:refresh": "tsx scripts/audit-high-conf.ts --refresh",
    "tags:audit:reset": "tsx scripts/audit-high-conf.ts --reset --refresh",
    "tags:links:local": "tsx scripts/run-link-autotagger.ts --once",
    "tags:links:local:all": "tsx scripts/run-link-autotagger.ts",
    "youtube:backfill:local": "tsx scripts/backfill-youtube-transcripts.ts",
    "tags:load:local": "tsx scripts/load-suggestions.ts > db/seed.suggestions.sql && wrangler d1 execute links-board-db --local --file=db/seed.suggestions.sql",
    "tags:load:remote": "tsx scripts/load-suggestions.ts > db/seed.suggestions.sql && wrangler d1 execute links-board-db --remote --file=db/seed.suggestions.sql",
    "tags:apply:local": "tsx scripts/auto-apply-high-conf.ts > db/seed.auto-apply-high.sql && wrangler d1 execute links-board-db --local --file=db/seed.auto-apply-high.sql",
    "tags:apply:remote": "tsx scripts/auto-apply-high-conf.ts --remote > db/seed.auto-apply-high.sql && wrangler d1 execute links-board-db --remote --file=db/seed.auto-apply-high.sql",
    "deploy": "vite build && wrangler deploy --keep-vars",
    "typecheck": "tsc --noEmit",
    "db:migrate:all:local": "for f in db/migrations/*.sql; do wrangler d1 execute links-board-db --local --file=\"$f\"; done",
    "db:migrate:all:remote": "for f in db/migrations/*.sql; do wrangler d1 execute links-board-db --remote --file=\"$f\"; done"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.113",
    "@chenglou/pretext": "0.0.7",
    "@cloudflare/sandbox": "^0.12.1",
    "@xenova/transformers": "^2.17.2",
    "ai": "^6.0.198",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.13",
    "short-uuid": "^5.2.0",
    "umap-js": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "autoprefixer": "^10.4.20",
    "better-sqlite3": "^12.10.0",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.9",
    "wait-on": "^9.0.10",
    "wrangler": "^4.101.0"
  }
}
